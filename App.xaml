<Application x:Class="ProgrammingPractice_L19.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ProgrammingPractice_L19"
             xmlns:view="clr-namespace:ProgrammingPractice_L19.Views"
             xmlns:vm="clr-namespace:ProgrammingPractice_L19.ViewModel"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:conv="clr-namespace:ProgrammingPractice_L19.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <hc:ThemeResources/>
                <hc:Theme/>

                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
                <Setter Property="Background" Value="BlueViolet"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="MinHeight" Value="40"/>
            </Style>

            <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlockBaseStyle}">
                <Setter Property="FontSize" Value="16"/>
            </Style>
            
            <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxBaseStyle}">
                <Setter Property="FontSize" Value="16"/>
            </Style>
            <Style TargetType="DatePicker" BasedOn="{StaticResource DatePickerBaseStyle}">
                <Setter Property="FontSize" Value="16"/>
            </Style>
            <conv:NullToVisibilityConverter x:Key="NullToVis"/>
            <conv:DateTimeToStringConverter x:Key="DateToString"/>
            <conv:BoolToVisibility x:Key="Bool2Vis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
