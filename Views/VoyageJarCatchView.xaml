<UserControl x:Class="ProgrammingPractice_L19.Views.VoyageJarCatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProgrammingPractice_L19.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="auto"></ColumnDefinition>
            <ColumnDefinition Width="auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Border Background="Beige">
            <DockPanel Grid.Row="0" Grid.Column="0"
                   Margin="5" LastChildFill="False" Background="Bisque">
                <TextBlock Text="Учёт посещённых банок" DockPanel.Dock="Top"
                           FontWeight="Bold" FontSize="30" Margin="0 5 0 0"/>
                
                <TextBox Margin="10 10 30 10" DockPanel.Dock="Top"/>

                <Button DockPanel.Dock="Right" Margin="5 0 30 15" Content="Добавить +"
                    MinHeight="30" Foreground="Bisque"
                    Command="{Binding StartAddingCommand}"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="0" Grid.Row="1" Background="Beige" >
            <DataGrid ItemsSource="{Binding DisplayVoyageJar}" Background="Bisque"
                  SelectedItem="{Binding SelectedCatchReport}" AutoGenerateColumns="False"
                  CanUserAddRows="False" FontSize="16"
                  RowBackground="Beige"
                  AlternatingRowBackground="BurlyWood" Margin="5"
                  SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя рейса" Binding="{Binding VoyageNumber}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Имя Банки" Binding="{Binding JarName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Имя рыбы" Binding="{Binding FishName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Качество" Binding="{Binding FishQuality}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Итоговый вес" Binding="{Binding FishWeight, StringFormat=({0})kg}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDown" Handler="DataGridRow_MouseDown"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>
        
        
        <Border Grid.Column="2" Grid.RowSpan="2" Background="Beige" MinWidth="350">
            <DockPanel Margin="5" Background="Bisque" LastChildFill="False">
                <TextBlock Text="{Binding Title}" FontSize="25"
               DockPanel.Dock="Top" Margin="10" FontWeight="Black"/>
                <Separator Margin="5" Background="BlueViolet" DockPanel.Dock="Top" Height="6"/>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Рейс" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding FinishedVoyages}"
                              SelectedItem="{Binding SelectedVoyage}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding VoyageNumber, StringFormat=№{0}}"></Run>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Банка" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding Jars}"
                              SelectedItem="{Binding SelectedJar}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Name}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Группа рыб" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding CatchedFish}"
                              SelectedItem="{Binding SelectedFish}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Name}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Качество" FontSize="14"/>
                    <TextBox Text="{Binding TextBoxQuality}"/>
                </StackPanel>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Количество" FontSize="14"/>
                    <TextBox Text="{Binding TextBoxWeight}"/>
                </StackPanel>
                <Button Content="{Binding ButtonCaption}" DockPanel.Dock="Top"
                        Foreground="Bisque" Margin="5"
                        Command="{Binding ApplyOperationCommand}"/>
                <Button Content="Удалить" DockPanel.Dock="Bottom" Margin="10"
            Visibility="{Binding SelectedVoyageJar,
                        Converter={StaticResource NullToVis}}"
            Command="{Binding RemoveCommand}"
            Background="Crimson"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
