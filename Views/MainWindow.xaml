<Window x:Class="ProgrammingPractice_L19.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProgrammingPractice_L19.Views"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/colors"
        xmlns:vm="clr-namespace:ProgrammingPractice_L19.ViewModel"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Title="MainWindow" Height="850" Width="800">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:BoatsViewModel}">
            <local:BoatView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:JarsViewModel}">
            <local:JarView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VoyagesViewModel}">
            <local:VoyageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FishermenViewModel}">
            <local:FishermenView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FishGroupViewModel}">
            <local:FishGroupView/>
        </DataTemplate>
        <!--6. для заданной банки вывести список катеров, которые получили улов выше среднего; -->
        <DataTemplate DataType="{x:Type vm:MoreThanAverageBoatCatchViewModel}">
            <local:MoreThanAverageCatchView/>
        </DataTemplate>
        <!--4. для указанного интервала дат вывести список банок, с указанием среднего улова за этот период;-->
        <DataTemplate DataType="{x:Type vm:JarCatchViewModel}">
            <local:JarCatchView/>
        </DataTemplate>
        <!--3. для указанного интервала дат вывести для каждого сорта рыбы список катеров с наибольшим уловом;-->
        <DataTemplate DataType="{x:Type vm:HigherFishCatchViewModel}">
            <local:HigherCatchView/>
        </DataTemplate>
        <!--7. вывести список сортов рыбы и для каждого сорта список рейсов с указанием даты выхода и возвращения, количества улова;-->
        <DataTemplate DataType="{x:Type vm:QualityByVoyagesViewModel}">
            <local:QualitiByVoyagesView/>
        </DataTemplate>
        <!--8. для выбранного пользователем рейса и банки добавить данные о сорте и количестве пойманной рыбы;-->
        <DataTemplate DataType="{x:Type vm:VoyageJarCatchViewModel}">
            <local:VoyageJarCatchView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VoyagesByJarAndFishViewModel}">
            <local:VoyagesByJarAndFishView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VoyageJarViewModel}">
            <local:VoyageJarView/>
        </DataTemplate>
    </Window.Resources>
    <Grid Background="Bisque">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Border Background="Beige">
            <StackPanel Background="Bisque" Margin="5">
                <Border Background="Bisque" Margin="2" CornerRadius="5">
                    <TextBlock Text="Navigation" FontSize="25" Margin="10" FontFamily="Segoe UI Black"/>
                </Border>
                <Separator Margin="5" Background="Violet"></Separator>
                <Button Content="Катера" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="boats"
                    Visibility="{Binding IsAdmin, Converter={StaticResource Bool2Vis}}"/>
                <Button Content="Рыбаки" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="fishermen"
                    Visibility="{Binding IsAdmin, Converter={StaticResource Bool2Vis}}"/>
                <Button Content="Банки" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="jars"
                    Visibility="{Binding IsAdmin, Converter={StaticResource Bool2Vis}}"/>
                <Button Content="Рейсы" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="voyages"
                    Visibility="{Binding IsAdmin, Converter={StaticResource Bool2Vis}}"/>
                <Button Content="Рыбы" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="fishgroups"
                    Visibility="{Binding IsAdmin, Converter={StaticResource Bool2Vis}}"/>
                <Separator Margin="5" Background="Violet"
                       Visibility="{Binding IsAdmin, Converter={StaticResource Bool2Vis}}"/>
                <Button Content="Наибольший улов" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="highercatch"/>
                <Button Content="Средний улов по Б." Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="averagecatchbyjar"/>
                <Button Content="Улов выше средн." Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="morethanaverage"/>
                <Button Content="Рейсы по банке и рыбе" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="voyagesbyjarandfish"/>
                <Button Content="Список сортов" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="qualitylist"/>
                <Separator Margin="5" Background="Violet"/>
                <Button Content="Добавить улов" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="voyagejarscatch"/>
                <Button Content="Посетить банку" Margin="8" Foreground="Bisque"
                    Command="{Binding NavigateToCommand}" CommandParameter="voyagejars"/>
            </StackPanel>
        </Border>
        
        <ContentControl Content="{Binding CurrentVM}" Grid.Column="1"/>
    </Grid>
</Window>
