<UserControl x:Class="ProgrammingPractice_L19.Views.FishGroupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProgrammingPractice_L19.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Border Background="Beige">
            <DockPanel Grid.Row="0" Grid.Column="0" Margin="5" LastChildFill="False" Background="Bisque">
                <TextBlock Text="База рыб" DockPanel.Dock="Top" FontWeight="Bold" FontSize="30" Margin="0 5 0 0"></TextBlock>
                <TextBox Margin="10 10 30 10" DockPanel.Dock="Top"/>

                <Button DockPanel.Dock="Right" Margin="5 0 30 15" Content="Добавить +"
                        MinHeight="30" Foreground="Bisque"
                        Command="{Binding PrepareToAddCommand}"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="0" Grid.Row="1" Background="Beige">
            <DataGrid ItemsSource="{Binding FishGroups}" Background="Bisque"
                      SelectedItem="{Binding SelectedFishGroup}" AutoGenerateColumns="False"
                      CanUserAddRows="False" FontSize="16"
                      RowBackground="Beige"
                      IsReadOnly="True"
                      AlternatingRowBackground="BurlyWood" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Качество" Binding="{Binding Quality}" Width="*"/>
                    <DataGridTextColumn Header="Вес" Binding="{Binding Weight}" Width="*"/>
                    <DataGridTextColumn Header="Номер рейса" Binding="{Binding VoyageJar.Voyage.VoyageNumber}" Width="*"/>
                    <DataGridTemplateColumn Header="Банка" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding VoyageJar.Jar.Name}"></Run>
                                    <Run Text="{Binding VoyageJar.PeriodId, StringFormat= ({0})}"></Run>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDown" Handler="DataGridRow_MouseDown"/>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" Grid.RowSpan="2" Background="Beige" Width="350">
            <DockPanel Margin="5" Background="Bisque" LastChildFill="False">
                <TextBlock Text="{Binding Title}" FontSize="25"
                           DockPanel.Dock="Top" Margin="10" FontWeight="Black"/>
                <Separator Margin="5" Background="BlueViolet" DockPanel.Dock="Top" Height="6"/>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Имя" FontSize="14"/>
                    <TextBox Text="{Binding TextBoxFishName}"/>
                </StackPanel>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Выберите рейс" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding Voyages}"
                              SelectedItem="{Binding SelectedVoyage}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding VoyageNumber, StringFormat=№{0}}"></Run>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="3" DockPanel.Dock="Top">
                    <TextBlock Text="Выберите банку" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding VoyageJars}"
                              SelectedItem="{Binding SelectedVoyageJar}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Jar.Name}"></Run>
                                    <Run Text="{Binding PeriodId, StringFormat=({0})}"></Run>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <Button Content="{Binding ButtonCaption}" DockPanel.Dock="Top"
                        Foreground="Bisque" Margin="5"
                        Command="{Binding ApplyOperationCommand}"/>
                <Button Content="Удалить" DockPanel.Dock="Bottom" Margin="5"
                        Visibility="{Binding SelectedFishGroup,
                            Converter={StaticResource NullToVis}}"
                        Command="{Binding RemoveCommand}"
                        Background="Crimson"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
